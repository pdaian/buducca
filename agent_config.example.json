{
  "collectors": {
    "gmail": {
      "accounts": [
        {
          "name": "personal",
          "command": "python3 /absolute/path/to/gmail_personal_export.py"
        },
        {
          "name": "work",
          "command": "python3 /absolute/path/to/gmail_work_export.py"
        }
      ]
    },
    "slack": {
      "accounts": [
        {
          "name": "workspace_a",
          "command": "python3 scripts/export_slack_recent_a.py"
        },
        {
          "name": "workspace_b",
          "command": "python3 scripts/export_slack_recent_b.py"
        }
      ]
    },
    "twitter_recent": {
      "accounts": [
        {
          "name": "main",
          "following_command": "python3 scripts/export_twitter_following.py",
          "dms_command": "python3 scripts/export_twitter_dms.py"
        }
      ]
    },
    "google_calendar": {
      "accounts": [
        "primary@example.com",
        {
          "name": "work@example.com",
          "command_template": "python3 collectors/google_calendar/google_calendar_api.py --account {account} --time-min {month_start} --time-max {month_end}"
        }
      ]
    }
  }
}
