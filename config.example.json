{
  "telegram": {
    "bot_token": "123456:replace-with-your-telegram-token",
    "poll_interval_seconds": 0.2,
    "long_poll_timeout_seconds": 30,
    "allowed_chat_ids": [],
    "read_only": false,
    "mode": "bot",
    "api_id": 123456,
    "api_hash": "replace-with-your-telegram-api-hash",
    "session_path": "workspace/telegram_user",
    "allowed_sender_ids": [],
    "allowed_group_ids_when_sender_not_allowed": [],
    "store_unanswered_messages": false
  },
  "signal": {
    "account": "+15551234567",
    "poll_interval_seconds": 0.5,
    "allowed_sender_ids": [],
    "allowed_group_ids_when_sender_not_allowed": [
      "AQi7f+/4S3mQv6s5hN2xwQ=="
    ],
    "receive_command": [
      "signal-cli",
      "-o",
      "json",
      "-a",
      "+15551234567",
      "receive",
      "--timeout",
      "1"
    ],
    "send_command": [
      "signal-cli",
      "-a",
      "+15551234567",
      "send",
      "-m",
      "{message}",
      "{recipient}"
    ],
    "read_only": false,
    "store_unanswered_messages": false
  },
  "whatsapp": {
    "account": "personal",
    "poll_interval_seconds": 1.0,
    "allowed_sender_ids": [],
    "allowed_group_ids_when_sender_not_allowed": [],
    "receive_command": [
      "python3",
      "scripts/whatsapp_receive.py"
    ],
    "send_command": [
      "python3",
      "scripts/whatsapp_send.py",
      "--recipient",
      "{recipient}",
      "--message",
      "{message}"
    ],
    "read_only": false,
    "store_unanswered_messages": false
  },
  "llm": {
    "base_url": "https://api.openai.com/v1",
    "api_key": "replace-with-api-key",
    "model": "gpt-4o-mini",
    "endpoint_path": "/chat/completions",
    "system_prompt": "You are a concise and helpful assistant.",
    "temperature": 0.2,
    "max_tokens": 400,
    "history_messages": 8,
    "system_prompt_timezone": "America/New_York",
    "file_task_layout_prompt": "Use the file skill as the default tool for personal tracking and organization tasks. Keep files under assistant/ grouped by domain (assistant/notes, assistant/lists, assistant/health, assistant/finance, assistant/people, assistant/travel). Prefer JSONL for append-only logs, JSON for mutable lists, and Markdown for readable notes."
  },
  "runtime": {
    "request_timeout_seconds": 300,
    "log_level": "INFO",
    "workspace_dir": "workspace",
    "collector_status_file": "collector_status.json",
    "skills_dir": "skills",
    "enable_voice_notes": false,
    "voice_transcribe_command": [
      "whisper",
      "--model",
      "base.en",
      "--output_dir",
      "{input_dir}",
      "--output_format",
      "txt",
      "{input}"
    ],
    "max_reply_chunk_chars": 4096,
    "debug": false,
    "file_skill_actions": [
      "read",
      "write",
      "append",
      "move",
      "create_dir",
      "delete_dir"
    ]
  },
  "google_fi": {
    "account": "personal",
    "poll_interval_seconds": 1.0,
    "allowed_sender_ids": [],
    "receive_command": [
      "python3",
      "scripts/google_fi_receive.py"
    ],
    "send_command": [
      "python3",
      "scripts/google_fi_send.py",
      "--recipient",
      "{recipient}",
      "--message",
      "{message}"
    ],
    "read_only": false,
    "store_unanswered_messages": false
  }
}
